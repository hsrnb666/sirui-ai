{
  "name": "ai-project",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "cd server && node index.js",
    "client": "cd client && npx vite --host",
    "build": "cd client && npx vite build",
        "predeploy": "npm run build",
        "deploy": "gh-pages -d client/dist"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "gh-pages": "^6.3.0",
    "localtunnel": "^2.0.2"
  }
}
